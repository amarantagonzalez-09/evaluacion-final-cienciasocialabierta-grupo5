@article{layeraInseguridadPercibidaBarrios2020,
  title = {{Inseguridad Percibida en los Barrios de Santiago de Chile: La Importancia del Bienestar Subjetivo}},
  shorttitle = {{Inseguridad Percibida en los Barrios de Santiago de Chile}},
  author = {Layera, Maria Luisa Mendez and Otero, Gabriel and Perret, Vania},
  year = 2020,
  journal = {Dados},
  volume = {63},
  pages = {e20170036},
  publisher = {Instituto de Estudos Sociais e Pol\'iticos (IESP) da Universidade do Estado do Rio de Janeiro (UERJ)},
  issn = {0011-5258, 1678-4588},
  doi = {10.1590/001152582020200},
  urldate = {2026-06-25},
  abstract = {Neste artigo estudamos os determinantes dos sentimentos de inseguran\c ca e o medo do crime em Santiago, Chile. Propomos um enfoque te\'orico integrador em torno ao conceito de ``bem-estar'', o qual permite resgatar tanto as dimens\~oes objetivas quanto as subjetivas expostas na literatura, assim como os distintos contextos analisados: individuais e geogr\'aficos. Utilizamos dados da Pesquisa COES de Coes\~ao e Conflito dos Bairros e dados georreferenciados no \^ambito da \'area censit\'aria. Os modelos de regress\~ao linear indicam que as vari\'aveis que capturam o bem-estar subjetivo no contexto do bairro s\~ao as mais significativas para entender as atitudes estudadas. Especificamente, as percep\c c\~oes de desordem f\'isica/social e as experi\^encias de vitimiza\c c\~ao indireta mostram associa\c c\~oes positivas; enquanto as disposi\c c\~oes de solidariedade institucional e apego/arraigo com a comunidade mostram associa\c c\~oes negativas com os sentimentos de inseguran\c ca e o medo ao crime dos residentes. No que diz respeito ao bem-estar objetivo, o capital econ\^omico individual \'e o \'unico fator que mant\'em sua signific\^ancia estat\'istica nas estima\c c\~oes finais. Os fatores objetivos do bairro como os n\'iveis de criminalidade, a concentra\c c\~ao da pobreza/riqueza, e os servi\c cos dispon\'iveis da vizinhan\c ca, n\~ao aparecem como preditores significativos depois de controlar o bem-estar subjetivo no contexto do bairro.sentimento de inseguran\c ca; medo do crime; bem-estar; coes\~ao do bairro; Am\'erica Latina},
  langid = {spanish},
  keywords = {America Latina,bienestar,cohesion barrial,miedo al crimen,sentimientos de inseguridad}
}
